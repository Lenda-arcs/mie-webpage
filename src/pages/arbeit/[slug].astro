---
import Layout from "../../layouts/Layout.astro";
import Container from "../../components/Container.astro";
import Header from "../../components/Header.astro";
import { site } from "../../content/site";

export function getStaticPaths() {
  return site.work.map((project, i) => {
    const next = site.work[(i + 1) % site.work.length];
    return { params: { slug: project.slug }, props: { project, next } };
  });
}

const { project, next } = Astro.props;

const meta = [
  { label: "Kunde", value: project.client },
  { label: "Leistung", value: project.role },
  { label: "Jahr", value: project.year },
].filter((m) => m.value);
---

<Layout title={`${project.title} – ${site.name}`}>
  <Header home={false} />

  <main>
    <!-- ── Titel ──────────────────────────────────────────── -->
    <Container class="pt-16 md:pt-24">
      <a href="/#arbeit" class="mb-8 inline-block text-xs font-bold uppercase tracking-[0.14em] text-muted transition-colors hover:text-coral">← Alle Arbeiten</a>
      <p class="text-sm font-bold uppercase tracking-[0.18em] text-coral" data-reveal>{project.tag}</p>
      <h1 class="mt-4 max-w-3xl text-5xl font-extrabold leading-[1.02] tracking-tight md:text-6xl" data-reveal>
        {project.title}
      </h1>
      {project.intro && (
        <p class="mt-7 max-w-2xl text-xl leading-relaxed text-muted" data-reveal>{project.intro}</p>
      )}

      {meta.length > 0 && (
        <dl class="mt-12 flex flex-wrap gap-x-16 gap-y-6 border-t border-line pt-8" data-reveal>
          {meta.map((m) => (
            <div>
              <dt class="text-xs font-bold uppercase tracking-[0.16em] text-coral">{m.label}</dt>
              <dd class="mt-1.5 text-lg font-semibold">{m.value}</dd>
            </div>
          ))}
        </dl>
      )}
    </Container>

    <!-- ── Hero-Bild ──────────────────────────────────────── -->
    <Container class="mt-12 md:mt-16">
      <div class="aspect-[16/9] overflow-hidden bg-blush/60" data-reveal>
        {project.image && <img src={project.image} alt={project.title} class="h-full w-full object-cover" />}
      </div>
    </Container>

    <!-- ── Inhalt (Blöcke) ────────────────────────────────── -->
    <Container class="py-16 md:py-24">
      <div class="space-y-14">
        {project.blocks.map((block) =>
          block.type === "text" ? (
            <p class="max-w-2xl text-xl leading-relaxed text-ink/90" data-reveal>{block.value}</p>
          ) : (
            <figure data-reveal>
              <div class="aspect-[16/10] overflow-hidden bg-blush/60">
                {block.src && <img src={block.src} alt={block.caption || project.title} class="h-full w-full object-cover" />}
              </div>
              {block.caption && <figcaption class="mt-3 text-sm text-muted">{block.caption}</figcaption>}
            </figure>
          ),
        )}
      </div>
    </Container>
  </main>

  <!-- ── Nächstes Projekt ─────────────────────────────────── -->
  <section class="border-t border-line">
    <Container class="py-20 md:py-28">
      <a href={`/arbeit/${next.slug}`} class="group block">
        <p class="text-sm font-bold uppercase tracking-[0.18em] text-coral">Nächstes Projekt</p>
        <h2 class="mt-4 flex items-center gap-4 text-3xl font-extrabold tracking-tight md:text-5xl">
          {next.title}
          <span class="text-coral transition-transform duration-300 group-hover:translate-x-2">→</span>
        </h2>
      </a>
    </Container>
  </section>

  <!-- ── Footer ───────────────────────────────────────────── -->
  <footer class="bg-ink text-white">
    <Container class="border-t border-white/10 py-12">
      <div class="flex flex-col gap-8 md:flex-row md:items-end md:justify-between">
        <p class="text-3xl font-extrabold tracking-tight md:text-4xl">{site.name}</p>
        <div class="flex flex-wrap gap-x-10 gap-y-2 text-sm font-medium uppercase tracking-[0.1em] text-white/60">
          <a href="/#kontakt" class="hover:text-coral">Kontakt</a>
          <a href={site.footer.linkedin} class="hover:text-coral" target="_blank" rel="noopener">LinkedIn</a>
          <a href="/impressum" class="hover:text-coral">Impressum</a>
          <a href="/datenschutz" class="hover:text-coral">Datenschutz</a>
        </div>
      </div>
    </Container>
  </footer>
</Layout>
